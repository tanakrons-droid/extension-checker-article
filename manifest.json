{
  "manifest_version": 3,
  "name": "VSQ CHECKER",
  "version": "1.0",
  "description": "Checks Table of Contents internal links for broken anchors.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open TOC Checker"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "icons": {
    "16": "favicon.png",
    "48": "favicon.png",
    "128": "favicon.png"
  }
}